#!/bin/sh
# Generate ~/.config/secrets/env.sh from secure secret stores.
# This runs during chezmoi apply, NOT on every shell startup.
set -eu

SECRETS_DIR="${HOME}/.config/secrets"
SECRETS_FILE="${SECRETS_DIR}/env.sh"
mkdir -p "${SECRETS_DIR}"
chmod 700 "${SECRETS_DIR}"

{{ if eq .chezmoi.os "darwin" -}}
# macOS: read all secrets from a single Keychain JSON entry
# Store secrets with:
#   security add-generic-password -a "$USER" -s "dotfiles-secrets" \
#     -w '{"KEY":"value","KEY2":"value2"}' -U login.keychain-db
# Note: Keychain returns hex-encoded data for values with special chars, so we decode with xxd
HEX=$(security find-generic-password -a "$USER" -s "dotfiles-secrets" -w 2>/dev/null || echo "")

if [ -z "${HEX}" ]; then
    echo "warning: no dotfiles-secrets entry found in Keychain, skipping secrets generation" >&2
    # Create empty file so sourcing doesn't fail
    : > "${SECRETS_FILE}"
else
    JSON=$(echo "${HEX}" | xxd -r -p)
    echo "# Generated by chezmoi - do not edit" > "${SECRETS_FILE}"
    echo "# Source: macOS Keychain (dotfiles-secrets)" >> "${SECRETS_FILE}"
    echo "${JSON}" | jq -r 'to_entries[] | "export \(.key)=\"\(.value)\""' >> "${SECRETS_FILE}"
fi
{{ else -}}
# Linux: decrypt SOPS-encrypted env file
SOPS_SOURCE="${HOME}/.config/secrets/env.sops.sh"

if [ ! -f "${SOPS_SOURCE}" ]; then
    echo "warning: ${SOPS_SOURCE} not found, skipping secrets generation" >&2
    : > "${SECRETS_FILE}"
else
    echo "# Generated by chezmoi - do not edit" > "${SECRETS_FILE}"
    echo "# Source: SOPS (env.sops.sh)" >> "${SECRETS_FILE}"
    sops -d "${SOPS_SOURCE}" >> "${SECRETS_FILE}"
fi
{{ end }}
chmod 600 "${SECRETS_FILE}"
